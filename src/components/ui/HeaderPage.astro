---
import AppPageHeader from "./primer/AppPageHeader";

const { title, subtitle = "", subtitleHtml = "", color = "blue", stackActionsOnMobile = false } = Astro.props;
---

<AppPageHeader
  title={title}
  subtitle={subtitle}
  subtitleHtml={subtitleHtml}
  color={color}
  stackActionsOnMobile={stackActionsOnMobile}
>
    <slot />
</AppPageHeader>
