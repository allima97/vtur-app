---
import "../../../styles/global.css";
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import RoteiroListIsland from "../../../components/islands/RoteiroListIsland";
import { createAstroServerClient } from "../../../lib/supabaseAstro";

const supabaseAuth = createAstroServerClient(Astro);

const {
  data: { user },
} = await supabaseAuth.auth.getUser();

if (!user) {
  return Astro.redirect("/auth/login");
}

const activePage = "orcamentos";
---

<DashboardLayout title="Roteiros Personalizados" {activePage}>

  <RoteiroListIsland client:load />
</DashboardLayout>
