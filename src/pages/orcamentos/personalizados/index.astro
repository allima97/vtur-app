---
import "../../../styles/global.css";
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import HeaderPage from "../../../components/ui/HeaderPage.astro";
import RoteiroListIsland from "../../../components/islands/RoteiroListIsland";
import { createServerClient } from "@supabase/ssr";
import { readEnv } from "../../../lib/supabaseServer";

const supabaseUrl = readEnv("PUBLIC_SUPABASE_URL");
const supabaseAnonKey = readEnv("PUBLIC_SUPABASE_ANON_KEY");
const isProd = readEnv("ENVIRONMENT") === "production" || readEnv("NODE_ENV") === "production";
const { cookies } = Astro;

const supabaseAuth = createServerClient(supabaseUrl, supabaseAnonKey, {
  cookies: {
    get: (name) => cookies.get(name)?.value ?? "",
    set: (name, value, options) =>
      cookies.set(name, value, {
        ...options,
        httpOnly: true,
        secure: isProd,
        sameSite: "Lax",
        path: "/",
      }),
    remove: (name, options) =>
      cookies.delete(name, {
        ...options,
        path: "/",
      }),
  },
});

const {
  data: { user },
} = await supabaseAuth.auth.getUser();

if (!user) {
  return Astro.redirect("/auth/login");
}

const activePage = "orcamentos";
---

<DashboardLayout title="Roteiros Personalizados" {activePage}>
  <HeaderPage
    title="Roteiros Personalizados"
    subtitle="Templates de roteiro para gerar orcamentos rapidamente."
    color="purple"
    stackActionsOnMobile={true}
  />

  <RoteiroListIsland client:load />
</DashboardLayout>
