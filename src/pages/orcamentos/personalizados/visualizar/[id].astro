---
import "../../../../styles/global.css";
import DashboardLayout from "../../../../layouts/DashboardLayout.astro";
import { createAstroServerClient } from "../../../../lib/supabaseAstro";
import { extractSeguroViagemIncludeLinesFromPasseios } from "../../../../lib/roteiroSeguro";

const supabaseAuth = createAstroServerClient(Astro);

const {
  data: { user },
} = await supabaseAuth.auth.getUser();

if (!user) {
  return Astro.redirect("/auth/login");
}

function formatDate(value?: string | null) {
  if (!value) return "";
  try {
    return new Date(value + "T12:00:00").toLocaleDateString("pt-BR");
  } catch {
    return String(value);
  }
}

function splitParagraphs(text?: string | null): string[] {
  const raw = String(text || "").trim();
  if (!raw) return [];
  return raw
    .split(/\n\s*\n+/)
    .map((p) => p.replace(/\n+/g, " ").replace(/\s+/g, " ").trim())
    .filter(Boolean);
}

function splitLines(text?: string | null): string[] {
  const raw = String(text || "").replace(/\r/g, "\n").trim();
  if (!raw) return [];
  return raw
    .split(/\n+/)
    .map((line) => line.replace(/\s+/g, " ").trim())
    .filter(Boolean);
}

function textValue(value?: string | null) {
  return String(value || "").trim();
}

function formatBudgetItemText(value?: string | null) {
  const raw = textValue(value);
  if (!raw) return "";
  const lowerWords = new Set([
    "a",
    "à",
    "ao",
    "aos",
    "as",
    "às",
    "com",
    "da",
    "das",
    "de",
    "do",
    "dos",
    "e",
    "em",
    "na",
    "nas",
    "no",
    "nos",
    "o",
    "os",
    "ou",
    "para",
    "por",
    "sem",
    "um",
    "uma",
    "uns",
    "umas",
  ]);
  let seenWord = false;
  return raw
    .split(/(\s+|\/|-|\(|\)|,|\+)/)
    .map((part) => {
      if (!part || /^(\s+|\/|-|\(|\)|,|\+)$/.test(part)) return part;
      if (/^[A-Z0-9]{2,4}$/.test(part)) return part;
      if (/^\d+$/.test(part)) return part;
      const lower = part.toLowerCase();
      const shouldLower = seenWord && lowerWords.has(lower);
      seenWord = true;
      if (shouldLower) return lower;
      return lower.charAt(0).toUpperCase() + lower.slice(1);
    })
    .join("");
}

function normalizeLookup(value?: string | null) {
  return textValue(value).toLocaleLowerCase();
}

function hasPositiveNumber(value?: number | string | null) {
  const n = Number(value);
  return Number.isFinite(n) && n > 0;
}

function formatCurrencyOptional(value?: number | null) {
  const n = Number(value || 0);
  if (!Number.isFinite(n) || n <= 0) return "";
  return `R$ ${n.toLocaleString("pt-BR", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
}

function splitTrechoCities(trecho?: string | null) {
  const parts = String(trecho || "")
    .split("-")
    .map((part) => part.trim())
    .filter(Boolean);
  return {
    origem: parts[0] || "",
    destino: parts[1] || "",
  };
}

function formatFlightPlace(city?: string | null, airport?: string | null) {
  const cityValue = formatBudgetItemText(city);
  const airportValue = textValue(airport).toUpperCase();
  if (cityValue && /^[A-Z]{3}$/.test(airportValue)) return `${cityValue} (${airportValue})`;
  return cityValue || airportValue;
}

function groupPasseiosByCidade(items: any[]) {
  const groups = new Map<string, { cidade: string; items: any[] }>();
  items.forEach((item) => {
    const cidade = formatBudgetItemText(item?.cidade) || "Serviços";
    const key = cidade.toLocaleLowerCase();
    if (!groups.has(key)) {
      groups.set(key, { cidade, items: [] });
    }
    groups.get(key)!.items.push(item);
  });

  return Array.from(groups.values()).map((group) => ({
    ...group,
    items: group.items
      .slice()
      .sort((a, b) => {
        const dateCompare = String(a?.data_inicio || "").localeCompare(String(b?.data_inicio || ""));
        if (dateCompare !== 0) return dateCompare;
        return formatBudgetItemText(a?.passeio).localeCompare(formatBudgetItemText(b?.passeio));
      }),
  }));
}

function hasMeaningfulHotel(h: any) {
  return Boolean(
    textValue(h?.cidade) ||
      textValue(h?.hotel) ||
      textValue(h?.endereco) ||
      textValue(h?.data_inicio) ||
      textValue(h?.data_fim) ||
      hasPositiveNumber(h?.qtd_apto) ||
      textValue(h?.apto) ||
      textValue(h?.categoria) ||
      textValue(h?.tipo_tarifa) ||
      hasPositiveNumber(h?.qtd_adultos) ||
      hasPositiveNumber(h?.qtd_criancas) ||
      hasPositiveNumber(h?.valor_original) ||
      hasPositiveNumber(h?.valor_final) ||
      textValue(h?.regime) ||
      hasPositiveNumber(h?.noites)
  );
}

function hasMeaningfulPasseio(p: any) {
  const tipoNorm = normalizeLookup(p?.tipo);
  const ingressosNorm = normalizeLookup(p?.ingressos);
  const tipoDefault = tipoNorm === "compartilhado";
  const ingressosDefault = ingressosNorm === "inclui ingressos";
  return Boolean(
    textValue(p?.cidade) ||
      textValue(p?.passeio) ||
      textValue(p?.fornecedor) ||
      textValue(p?.data_inicio) ||
      textValue(p?.data_fim) ||
      hasPositiveNumber(p?.qtd_adultos) ||
      hasPositiveNumber(p?.qtd_criancas) ||
      hasPositiveNumber(p?.valor_original) ||
      hasPositiveNumber(p?.valor_final) ||
      (textValue(p?.tipo) && !tipoDefault) ||
      (textValue(p?.ingressos) && !ingressosDefault)
  );
}

function hasMeaningfulTransporte(t: any) {
  return Boolean(
    textValue(t?.trecho) ||
      textValue(t?.cia_aerea) ||
      textValue(t?.data_voo) ||
      textValue(t?.classe_reserva) ||
      textValue(t?.hora_saida) ||
      textValue(t?.aeroporto_saida) ||
      textValue(t?.duracao_voo) ||
      textValue(t?.tipo_voo) ||
      textValue(t?.hora_chegada) ||
      textValue(t?.aeroporto_chegada) ||
      textValue(t?.tarifa_nome) ||
      textValue(t?.reembolso_tipo) ||
      hasPositiveNumber(t?.qtd_adultos) ||
      hasPositiveNumber(t?.qtd_criancas) ||
      hasPositiveNumber(t?.taxas) ||
      hasPositiveNumber(t?.valor_total) ||
      textValue(t?.tipo) ||
      textValue(t?.fornecedor) ||
      textValue(t?.descricao) ||
      textValue(t?.data_inicio) ||
      textValue(t?.data_fim) ||
      textValue(t?.categoria) ||
      textValue(t?.observacao)
  );
}

function hasMeaningfulInvestimento(i: any) {
  const qtd = Number(i?.qtd_apto || 0);
  return Boolean(
    textValue(i?.tipo) ||
      hasPositiveNumber(i?.valor_por_pessoa) ||
      hasPositiveNumber(i?.valor_por_apto) ||
      (Number.isFinite(qtd) && qtd > 1)
  );
}

function hasMeaningfulPagamento(p: any) {
  return Boolean(
    textValue(p?.servico) ||
      textValue(p?.forma_pagamento) ||
      hasPositiveNumber(p?.valor_total_com_taxas) ||
      hasPositiveNumber(p?.taxas)
  );
}

function normalizeDiaKey(d: { cidade?: string | null; percurso?: string | null; data?: string | null; descricao?: string | null }): string {
  const cidade = String(d.cidade || "").trim().toLocaleLowerCase();
  const percurso = String(d.percurso || "").trim().toLocaleLowerCase();
  const data = String(d.data || "").trim();
  const descricao = String(d.descricao || "").trim().toLocaleLowerCase();
  return `${data}__${cidade}__${percurso}__${descricao}`;
}

function isMissingPercursoColumn(error: any) {
  const code = String(error?.code || "");
  const msg = String(error?.message || "");
  return (
    code === "42703" ||
    (/percurso/i.test(msg) && /does not exist|nao existe|não existe|unknown column|column/i.test(msg))
  );
}

function normalizeDiasForView(
  dias: Array<{ id?: string; cidade?: string | null; percurso?: string | null; data?: string | null; descricao?: string | null; ordem?: number | null }>
) {
  const sorted = (dias || [])
    .slice()
    .sort((a, b) => (a.ordem ?? 0) - (b.ordem ?? 0))
    .map((d) => ({
      ...d,
      percurso: String((d as any).percurso || "").trim(),
      cidade: String(d.cidade || "").trim(),
      data: String(d.data || "").trim(),
      descricao: String(d.descricao || "").trim(),
    }))
    .filter((d) => Boolean((d as any).percurso || d.cidade || d.data || d.descricao));

  const seen = new Set<string>();
  const unique: typeof sorted = [];
  for (const d of sorted) {
    const key = normalizeDiaKey(d);
    if (seen.has(key)) continue;
    seen.add(key);
    unique.push(d);
  }
  return unique;
}

function toDateOrNull(value?: string | null) {
  const v = String(value || "").trim();
  if (!v) return null;
  const date = new Date(`${v}T12:00:00`);
  if (Number.isNaN(date.getTime())) return null;
  return date;
}

const { id } = Astro.params;
const roteiroId = String(id || "").trim();
if (!roteiroId) return Astro.redirect("/orcamentos/personalizados");

const selectWithPercurso = `id, nome, duracao, inicio_cidade, fim_cidade, inclui_texto, nao_inclui_texto, informacoes_importantes,
     roteiro_hotel (id, cidade, hotel, endereco, data_inicio, data_fim, noites, qtd_apto, apto, categoria, regime, tipo_tarifa, qtd_adultos, qtd_criancas, valor_original, valor_final, ordem),
     roteiro_passeio (id, cidade, passeio, fornecedor, data_inicio, data_fim, tipo, ingressos, qtd_adultos, qtd_criancas, valor_original, valor_final, ordem),
     roteiro_transporte (id, trecho, cia_aerea, data_voo, classe_reserva, hora_saida, aeroporto_saida, duracao_voo, tipo_voo, hora_chegada, aeroporto_chegada, tarifa_nome, reembolso_tipo, qtd_adultos, qtd_criancas, taxas, valor_total, tipo, fornecedor, descricao, data_inicio, data_fim, categoria, observacao, ordem),
     roteiro_dia (id, percurso, cidade, data, descricao, ordem),
     roteiro_investimento (id, tipo, valor_por_pessoa, qtd_apto, valor_por_apto, ordem),
     roteiro_pagamento (id, servico, valor_total_com_taxas, taxas, forma_pagamento, ordem)`;

const selectWithoutPercurso = `id, nome, duracao, inicio_cidade, fim_cidade, inclui_texto, nao_inclui_texto, informacoes_importantes,
     roteiro_hotel (id, cidade, hotel, endereco, data_inicio, data_fim, noites, qtd_apto, apto, categoria, regime, tipo_tarifa, qtd_adultos, qtd_criancas, valor_original, valor_final, ordem),
     roteiro_passeio (id, cidade, passeio, fornecedor, data_inicio, data_fim, tipo, ingressos, qtd_adultos, qtd_criancas, valor_original, valor_final, ordem),
     roteiro_transporte (id, trecho, cia_aerea, data_voo, classe_reserva, hora_saida, aeroporto_saida, duracao_voo, tipo_voo, hora_chegada, aeroporto_chegada, tarifa_nome, reembolso_tipo, qtd_adultos, qtd_criancas, taxas, valor_total, tipo, fornecedor, descricao, data_inicio, data_fim, categoria, observacao, ordem),
     roteiro_dia (id, cidade, data, descricao, ordem),
     roteiro_investimento (id, tipo, valor_por_pessoa, qtd_apto, valor_por_apto, ordem),
     roteiro_pagamento (id, servico, valor_total_com_taxas, taxas, forma_pagamento, ordem)`;

let res = await supabaseAuth.from("roteiro_personalizado").select(selectWithPercurso).eq("id", roteiroId).maybeSingle();
if (res.error && isMissingPercursoColumn(res.error)) {
  res = await supabaseAuth.from("roteiro_personalizado").select(selectWithoutPercurso).eq("id", roteiroId).maybeSingle();
}

if (res.error || !res.data) {
  return Astro.redirect("/orcamentos/personalizados");
}

const roteiro: any = res.data;
const dias = normalizeDiasForView(roteiro.roteiro_dia || []);

const hoteis = (roteiro.roteiro_hotel || [])
  .slice()
  .sort((a: any, b: any) => (a.ordem ?? 0) - (b.ordem ?? 0))
  .filter((h: any) => hasMeaningfulHotel(h));

const passeios = (roteiro.roteiro_passeio || [])
  .slice()
  .sort((a: any, b: any) => (a.ordem ?? 0) - (b.ordem ?? 0))
  .filter((p: any) => hasMeaningfulPasseio(p));

const transportes = (roteiro.roteiro_transporte || [])
  .slice()
  .sort((a: any, b: any) => (a.ordem ?? 0) - (b.ordem ?? 0))
  .filter((t: any) => hasMeaningfulTransporte(t));

const investimentos = (roteiro.roteiro_investimento || [])
  .slice()
  .sort((a: any, b: any) => (a.ordem ?? 0) - (b.ordem ?? 0))
  .filter((i: any) => hasMeaningfulInvestimento(i));

const pagamentos = (roteiro.roteiro_pagamento || [])
  .slice()
  .sort((a: any, b: any) => (a.ordem ?? 0) - (b.ordem ?? 0))
  .filter((p: any) => hasMeaningfulPagamento(p));

const incluiBaseItems = splitLines(roteiro?.inclui_texto);
const incluiSeguroItems = extractSeguroViagemIncludeLinesFromPasseios(passeios || []);
const incluiSeen = new Set<string>();
const incluiItems = [...incluiBaseItems, ...incluiSeguroItems].filter((item) => {
  const key = normalizeLookup(item);
  if (!key || incluiSeen.has(key)) return false;
  incluiSeen.add(key);
  return true;
});
const naoIncluiItems = splitLines(roteiro?.nao_inclui_texto);

const infoImportanteItems = splitLines(roteiro?.informacoes_importantes || "");

const dateCandidates: Date[] = [];
for (const d of dias) {
  const dt = toDateOrNull(d.data);
  if (dt) dateCandidates.push(dt);
}
for (const h of hoteis) {
  const di = toDateOrNull(h.data_inicio);
  const df = toDateOrNull(h.data_fim);
  if (di) dateCandidates.push(di);
  if (df) dateCandidates.push(df);
}
for (const p of passeios) {
  const di = toDateOrNull(p.data_inicio);
  const df = toDateOrNull(p.data_fim);
  if (di) dateCandidates.push(di);
  if (df) dateCandidates.push(df);
}
for (const t of transportes) {
  const di = toDateOrNull(t.data_inicio);
  const df = toDateOrNull(t.data_fim);
  if (di) dateCandidates.push(di);
  if (df) dateCandidates.push(df);
}

let startDate: Date | null = null;
let endDate: Date | null = null;
if (dateCandidates.length) {
  startDate = dateCandidates.reduce((min, d) => (d.getTime() < min.getTime() ? d : min), dateCandidates[0]);
  endDate = dateCandidates.reduce((max, d) => (d.getTime() > max.getTime() ? d : max), dateCandidates[0]);
}

const periodLabel =
  startDate && endDate
    ? `${startDate.toLocaleDateString("pt-BR")} a ${endDate.toLocaleDateString("pt-BR")}`
    : hasPositiveNumber(roteiro?.duracao)
      ? `${Number(roteiro.duracao)} dias`
      : "";

const resumoViagem = [
  { label: "Origem", value: formatBudgetItemText(roteiro?.inicio_cidade) },
  { label: "Destino", value: formatBudgetItemText(roteiro?.fim_cidade) },
  { label: "Período", value: periodLabel },
].filter((item) => Boolean(item.value));

const activePage = "orcamentos";
const pageTitle = `Visualizar: ${roteiro?.nome || "Orçamento"}`;
---

<DashboardLayout title={pageTitle} {activePage}>
  <div class="page-content-wrap">
    <section class="vtur-app-card vtur-app-card-info mb-3 list-toolbar-sticky">
      <div class="vtur-app-card-header">
        <div class="vtur-app-card-copy">
          <h2 class="vtur-app-card-title">{roteiro?.nome || "Orçamento Personalizado"}</h2>
          <p class="vtur-app-card-subtitle">Visualização em HTML (sem PDF).</p>
        </div>
      </div>
      <div class="vtur-app-card-body">
        <div class="mobile-stack-buttons orcamentos-action-bar vtur-actions-end">
          <a class="vtur-app-button vtur-app-button-primary" href={`/orcamentos/personalizados/${roteiroId}`}>Editar</a>
          <a class="vtur-app-button" href={`/orcamentos/personalizados/novo?duplicar=${roteiroId}`}>Duplicar</a>
          <a class="vtur-app-button" href="/orcamentos/personalizados">Voltar</a>
        </div>
      </div>
    </section>
  </div>

  <div class="px-6 pb-10">
    <div class="max-w-5xl mx-auto space-y-4">
      {resumoViagem.length > 0 ? (
        <div class="bg-white border border-slate-200 rounded-xl p-5">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {resumoViagem.map((item) => (
              <div>
                <div class="text-xs font-semibold text-slate-600">{item.label}</div>
                <div class="text-base text-slate-900 mt-1">{item.value}</div>
              </div>
            ))}
          </div>
        </div>
      ) : null}

      {dias.length > 0 ? (
        <div class="bg-white border border-slate-200 rounded-xl p-5">
          <div class="vtur-quote-circuit-panel roteiro-visual-circuit-panel">
            <div class="vtur-quote-circuit-days-head">
              <div>
                <div class="text-lg md:text-xl font-extrabold text-blue-title">Itinerário Detalhado</div>
                <p>Dia a dia no mesmo padrão visual de Circuitos.</p>
              </div>
            </div>
            <div class="vtur-quote-circuit-days-list roteiro-visual-circuit-days-list">
              {dias.map((d: any, idx: number) => {
                const place = formatBudgetItemText(d.percurso) || formatBudgetItemText(d.cidade);
                const header = `Dia ${idx + 1}${place ? `: ${place}` : ""}`;
                const dateLabel = formatDate(d.data);
                const items = splitParagraphs(d.descricao);
                return (
                  <div class="vtur-quote-circuit-day roteiro-visual-circuit-day">
                    <div class="roteiro-visual-circuit-day-content">
                      <div class="text-sm font-semibold text-slate-900">{header}</div>
                      {dateLabel ? <div class="mt-1 text-xs font-medium text-slate-500">{dateLabel}</div> : null}
                      {items.length > 0 ? (
                        <div class="mt-3 text-sm text-slate-700 space-y-1 roteiro-visual-circuit-copy">
                          {items.map((it) => (
                            <p class="roteiro-visual-circuit-paragraph">{it}</p>
                          ))}
                        </div>
                      ) : null}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      ) : null}

      {hoteis.length > 0 ? (
        <div class="bg-white border border-slate-200 rounded-xl p-5">
          <div class="text-lg md:text-xl font-extrabold text-blue-title">Hotéis Sugeridos</div>
          <div class="mt-4 overflow-x-auto">
            <table class="table-default table-header-blue hotel-resumo-table" style="width: 100%; min-width: 980px;">
              <colgroup>
                <col style="width: 14%" />
                <col style="width: 24%" />
                <col style="width: 11%" />
                <col style="width: 11%" />
                <col style="width: 8%" />
                <col style="width: 20%" />
                <col style="width: 12%" />
              </colgroup>
              <thead>
                <tr>
                  <th>Cidade</th>
                  <th>Hotel</th>
                  <th>De</th>
                  <th>Até</th>
                  <th>Noites</th>
                  <th>Acomodação</th>
                  <th>Regime</th>
                </tr>
              </thead>
              <tbody>
                {hoteis.map((h: any) => (
                  <tr>
                    <td>{formatBudgetItemText(h.cidade) || "-"}</td>
                    <td>{formatBudgetItemText(h.hotel) || "-"}</td>
                    <td>{formatDate(h.data_inicio) || "-"}</td>
                    <td>{formatDate(h.data_fim) || "-"}</td>
                    <td>{hasPositiveNumber(h.noites) ? String(Number(h.noites)) : "-"}</td>
                    <td>{formatBudgetItemText(h.apto) || "-"}</td>
                    <td>{formatBudgetItemText(h.regime) || "-"}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      ) : null}

      {passeios.length > 0 ? (
        <div class="bg-white border border-slate-200 rounded-xl p-5">
          <div class="text-lg md:text-xl font-extrabold text-blue-title">Passeios e Serviços</div>
          <div class="mt-4 space-y-4">
            {groupPasseiosByCidade(passeios).map((group) => (
              <div class="border border-slate-200 rounded-lg p-4">
                <div class="text-sm font-semibold text-slate-900">{group.cidade}</div>
                <div class="mt-5 overflow-x-auto">
                  <table class="table-default table-header-blue passeio-resumo-table" style="width: 100%; min-width: 760px;">
                    <colgroup>
                      <col style="width: 16%" />
                      <col style="width: 62%" />
                      <col style="width: 22%" />
                    </colgroup>
                    <thead>
                      <tr>
                        <th>Data</th>
                        <th>Descrição</th>
                        <th>Ingressos</th>
                      </tr>
                    </thead>
                    <tbody>
                      {group.items.map((p: any) => {
                        const di = formatDate(p.data_inicio);
                        const df = formatDate(p.data_fim);
                        const when = di && df ? (di === df ? di : `${di} a ${df}`) : di || df;
                        return (
                          <tr>
                            <td>{when || "-"}</td>
                            <td>{formatBudgetItemText(p.passeio) || "-"}</td>
                            <td>{formatBudgetItemText(p.ingressos) || "-"}</td>
                          </tr>
                        );
                      })}
                    </tbody>
                  </table>
                </div>
              </div>
            ))}
          </div>
        </div>
      ) : null}

      {transportes.length > 0 ? (
        <div class="bg-white border border-slate-200 rounded-xl p-5">
          <div class="text-lg md:text-xl font-extrabold text-blue-title flex items-center gap-2">
            <i class="pi pi-ticket" aria-hidden="true"></i>
            <span>Passagem Aérea</span>
          </div>
          <div class="mt-4 overflow-x-auto">
            <div class="roteiro-voos-grid" style="min-width: 1140px;">
              <div class="roteiro-voos-grid-head">
                <div>Cia Aérea</div>
                <div>De</div>
                <div>Data</div>
                <div>Para</div>
                <div>Data</div>
                <div>Saída/Chegada</div>
              </div>
              <div class="roteiro-voos-grid-body">
                {transportes.map((t: any) => {
                  const trecho = splitTrechoCities(t.trecho);
                  const horaSaida = textValue(t.hora_saida);
                  const horaChegada = textValue(t.hora_chegada);
                  const horarios = horaSaida && horaChegada ? `${horaSaida} / ${horaChegada}` : horaSaida || horaChegada;
                  return (
                    <div class="roteiro-voos-grid-row">
                      <div>{formatBudgetItemText(t.cia_aerea) || "-"}</div>
                      <div>{formatFlightPlace(trecho.origem, t.aeroporto_saida) || "-"}</div>
                      <div>{formatDate(t.data_voo || t.data_inicio) || "-"}</div>
                      <div>{formatFlightPlace(trecho.destino, t.aeroporto_chegada) || "-"}</div>
                      <div>{formatDate(t.data_fim || t.data_voo || t.data_inicio) || "-"}</div>
                      <div>{horarios || "-"}</div>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        </div>
      ) : null}

      {investimentos.length > 0 ? (
        <div class="bg-white border border-slate-200 rounded-xl p-5">
          <div class="text-lg md:text-xl font-extrabold text-blue-title">Investimento</div>
          <div class="mt-4 space-y-3">
            {investimentos.map((i: any) => {
              const tipo = formatBudgetItemText(i.tipo);
              const valorPessoa = formatCurrencyOptional(i.valor_por_pessoa);
              const valorApto = formatCurrencyOptional(i.valor_por_apto);
              const qtd = Number(i.qtd_apto || 0);
              const showQtd =
                Number.isFinite(qtd) &&
                qtd > 0 &&
                (qtd > 1 || Boolean(valorPessoa) || Boolean(valorApto));
              const details = [
                valorPessoa ? `Valor por pessoa: ${valorPessoa}` : "",
                showQtd ? `Qte Pax: ${qtd}` : "",
                valorApto ? `Valor por apto: ${valorApto}` : "",
              ].filter(Boolean);
              if (!tipo && details.length === 0) return null;
              return (
                <div class="border border-slate-200 rounded-lg p-4">
                  {tipo ? <div class="text-sm font-semibold text-slate-900">{tipo}</div> : null}
                  {details.length > 0 ? (
                    <ul class="mt-2 list-disc pl-5 text-sm text-slate-700 space-y-1">
                      {details.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  ) : null}
                </div>
              );
            })}
          </div>
        </div>
      ) : null}

      {pagamentos.length > 0 ? (
        <div class="bg-white border border-slate-200 rounded-xl p-5">
          <div class="text-lg md:text-xl font-extrabold text-blue-title">Formas de Pagamento</div>
          <div class="mt-4 space-y-3">
            {pagamentos.map((p: any) => {
              const servico = formatBudgetItemText(p.servico);
              const valorTotal = formatCurrencyOptional(p.valor_total_com_taxas);
              const taxas = formatCurrencyOptional(p.taxas);
              const formas = splitLines(p.forma_pagamento || "").map((item) => formatBudgetItemText(item));
              const details = [
                valorTotal ? `Valor total c/ taxas: ${valorTotal}` : "",
                taxas ? `Taxas: ${taxas}` : "",
              ].filter(Boolean);
              if (!servico && details.length === 0 && formas.length === 0) return null;
              return (
                <div class="border border-slate-200 rounded-lg p-4">
                  {servico ? <div class="text-sm font-semibold text-slate-900">{servico}</div> : null}
                  {details.length > 0 ? (
                    <ul class="mt-2 list-disc pl-5 text-sm text-slate-700 space-y-1">
                      {details.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  ) : null}
                  {formas.length === 1 ? (
                    <div class="mt-2 text-sm text-slate-700">Forma: {formas[0]}</div>
                  ) : null}
                  {formas.length > 1 ? (
                    <div class="mt-2">
                      <div class="text-sm font-semibold text-slate-900">Formas</div>
                      <ul class="mt-1 list-disc pl-5 text-sm text-slate-700 space-y-1">
                        {formas.map((it: string) => (
                          <li>{it}</li>
                        ))}
                      </ul>
                    </div>
                  ) : null}
                </div>
              );
            })}
          </div>
        </div>
      ) : null}

      {incluiItems.length > 0 || naoIncluiItems.length > 0 ? (
        <>
          <!-- Incluído / Não Incluído -->
          <div class="bg-white border border-slate-200 rounded-xl p-4">
            <div class="text-lg md:text-xl font-extrabold text-blue-title">Incluído / Não Incluído</div>
          </div>
          <div class="bg-white border border-slate-200 rounded-xl p-5">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {incluiItems.length > 0 ? (
                <div class="border border-slate-200 rounded-lg p-4">
                  <div class="text-sm font-semibold text-slate-900">Incluído</div>
                  <ul class="mt-2 list-disc pl-5 text-sm text-slate-700 space-y-1">
                    {incluiItems.map((it) => (
                      <li>{it}</li>
                    ))}
                  </ul>
                </div>
              ) : null}
              {naoIncluiItems.length > 0 ? (
                <div class="border border-slate-200 rounded-lg p-4">
                  <div class="text-sm font-semibold text-slate-900">Não Incluído</div>
                  <ul class="mt-2 list-disc pl-5 text-sm text-slate-700 space-y-1">
                    {naoIncluiItems.map((it) => (
                      <li>{it}</li>
                    ))}
                  </ul>
                </div>
              ) : null}
            </div>
          </div>
        </>
      ) : null}

      {infoImportanteItems.length > 0 ? (
        <>
          <!-- Informações Importantes -->
          <div class="bg-white border border-slate-200 rounded-xl p-4">
            <div class="text-lg md:text-xl font-extrabold text-blue-title">Informações Importantes</div>
          </div>
          <div class="bg-white border border-slate-200 rounded-xl p-5">
            <ul class="list-disc pl-5 text-sm text-slate-700 space-y-1">
              {infoImportanteItems.map((it) => (
                <li>{it}</li>
              ))}
            </ul>
          </div>
        </>
      ) : null}
    </div>
  </div>
</DashboardLayout>
