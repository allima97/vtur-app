---
import "../../../../styles/global.css";
import DashboardLayout from "../../../../layouts/DashboardLayout.astro";
import HeaderPage from "../../../../components/ui/HeaderPage.astro";
import { createServerClient } from "@supabase/ssr";
import { readEnv } from "../../../../lib/supabaseServer";

const supabaseUrl = readEnv("PUBLIC_SUPABASE_URL");
const supabaseAnonKey = readEnv("PUBLIC_SUPABASE_ANON_KEY");
const isProd = readEnv("ENVIRONMENT") === "production" || readEnv("NODE_ENV") === "production";
const { cookies } = Astro;

const supabaseAuth = createServerClient(supabaseUrl, supabaseAnonKey, {
  cookies: {
    get: (name) => cookies.get(name)?.value ?? "",
    set: (name, value, options) =>
      cookies.set(name, value, {
        ...options,
        httpOnly: true,
        secure: isProd,
        sameSite: "Lax",
        path: "/",
      }),
    remove: (name, options) =>
      cookies.delete(name, {
        ...options,
        path: "/",
      }),
  },
});

const {
  data: { user },
} = await supabaseAuth.auth.getUser();

if (!user) {
  return Astro.redirect("/auth/login");
}

function formatDate(value?: string | null) {
  if (!value) return "";
  try {
    return new Date(value + "T12:00:00").toLocaleDateString("pt-BR");
  } catch {
    return String(value);
  }
}

function formatCurrency(value?: number | null) {
  const n = Number(value || 0);
  if (!Number.isFinite(n)) return "R$ 0,00";
  return `R$ ${n.toLocaleString("pt-BR", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
}

function splitParagraphs(text?: string | null): string[] {
  const raw = String(text || "").trim();
  if (!raw) return [];
  return raw
    .split(/\n\s*\n+/)
    .map((p) => p.replace(/\n+/g, " ").replace(/\s+/g, " ").trim())
    .filter(Boolean);
}

function splitLines(text?: string | null): string[] {
  const raw = String(text || "").replace(/\r/g, "\n").trim();
  if (!raw) return [];
  return raw
    .split(/\n+/)
    .map((line) => line.replace(/\s+/g, " ").trim())
    .filter(Boolean);
}

function normalizeDiaKey(d: { cidade?: string | null; percurso?: string | null; data?: string | null; descricao?: string | null }): string {
  const cidade = String(d.cidade || "").trim().toLocaleLowerCase();
  const percurso = String(d.percurso || "").trim().toLocaleLowerCase();
  const data = String(d.data || "").trim();
  const descricao = String(d.descricao || "").trim().toLocaleLowerCase();
  return `${data}__${cidade}__${percurso}__${descricao}`;
}

function isMissingPercursoColumn(error: any) {
  const code = String(error?.code || "");
  const msg = String(error?.message || "");
  return (
    code === "42703" ||
    (/percurso/i.test(msg) && /does not exist|nao existe|não existe|unknown column|column/i.test(msg))
  );
}

function normalizeDiasForView(
  dias: Array<{ id?: string; cidade?: string | null; percurso?: string | null; data?: string | null; descricao?: string | null; ordem?: number | null }>
) {
  const sorted = (dias || [])
    .slice()
    .sort((a, b) => (a.ordem ?? 0) - (b.ordem ?? 0))
    .map((d) => ({
      ...d,
      percurso: String((d as any).percurso || "").trim(),
      cidade: String(d.cidade || "").trim(),
      data: String(d.data || "").trim(),
      descricao: String(d.descricao || "").trim(),
    }))
    .filter((d) => Boolean((d as any).percurso || d.cidade || d.data || d.descricao));

  const seen = new Set<string>();
  const unique: typeof sorted = [];
  for (const d of sorted) {
    const key = normalizeDiaKey(d);
    if (seen.has(key)) continue;
    seen.add(key);
    unique.push(d);
  }
  return unique;
}

function toDateOrNull(value?: string | null) {
  const v = String(value || "").trim();
  if (!v) return null;
  const date = new Date(`${v}T12:00:00`);
  if (Number.isNaN(date.getTime())) return null;
  return date;
}

const { id } = Astro.params;
const roteiroId = String(id || "").trim();
if (!roteiroId) return Astro.redirect("/orcamentos/personalizados");

const selectWithPercurso = `id, nome, duracao, inicio_cidade, fim_cidade, inclui_texto, nao_inclui_texto, informacoes_importantes,
     roteiro_hotel (id, cidade, hotel, data_inicio, data_fim, noites, apto, categoria, regime, ordem),
     roteiro_passeio (id, cidade, passeio, data_inicio, data_fim, tipo, ingressos, ordem),
     roteiro_transporte (id, tipo, fornecedor, descricao, data_inicio, data_fim, categoria, observacao, ordem),
     roteiro_dia (id, percurso, cidade, data, descricao, ordem),
     roteiro_investimento (id, tipo, valor_por_pessoa, qtd_apto, valor_por_apto, ordem),
     roteiro_pagamento (id, servico, valor_total_com_taxas, taxas, forma_pagamento, ordem)`;

const selectWithoutPercurso = `id, nome, duracao, inicio_cidade, fim_cidade, inclui_texto, nao_inclui_texto, informacoes_importantes,
     roteiro_hotel (id, cidade, hotel, data_inicio, data_fim, noites, apto, categoria, regime, ordem),
     roteiro_passeio (id, cidade, passeio, data_inicio, data_fim, tipo, ingressos, ordem),
     roteiro_transporte (id, tipo, fornecedor, descricao, data_inicio, data_fim, categoria, observacao, ordem),
     roteiro_dia (id, cidade, data, descricao, ordem),
     roteiro_investimento (id, tipo, valor_por_pessoa, qtd_apto, valor_por_apto, ordem),
     roteiro_pagamento (id, servico, valor_total_com_taxas, taxas, forma_pagamento, ordem)`;

let res = await supabaseAuth.from("roteiro_personalizado").select(selectWithPercurso).eq("id", roteiroId).maybeSingle();
if (res.error && isMissingPercursoColumn(res.error)) {
  res = await supabaseAuth.from("roteiro_personalizado").select(selectWithoutPercurso).eq("id", roteiroId).maybeSingle();
}

if (res.error || !res.data) {
  return Astro.redirect("/orcamentos/personalizados");
}

const roteiro: any = res.data;
const dias = normalizeDiasForView(roteiro.roteiro_dia || []);

const hoteis = (roteiro.roteiro_hotel || [])
  .slice()
  .sort((a: any, b: any) => (a.ordem ?? 0) - (b.ordem ?? 0))
  .filter((h: any) => {
    return Boolean(
      String(h.cidade || "").trim() ||
        String(h.hotel || "").trim() ||
        String(h.data_inicio || "").trim() ||
        String(h.data_fim || "").trim() ||
        String(h.apto || "").trim() ||
        String(h.regime || "").trim() ||
        String(h.categoria || "").trim() ||
        Number.isFinite(Number(h.noites))
    );
  });

const passeios = (roteiro.roteiro_passeio || [])
  .slice()
  .sort((a: any, b: any) => (a.ordem ?? 0) - (b.ordem ?? 0))
  .filter((p: any) => {
    return Boolean(
      String(p.cidade || "").trim() ||
        String(p.passeio || "").trim() ||
        String(p.data_inicio || "").trim() ||
        String(p.data_fim || "").trim() ||
        String(p.tipo || "").trim() ||
        String(p.ingressos || "").trim()
    );
  });

const transportes = (roteiro.roteiro_transporte || [])
  .slice()
  .sort((a: any, b: any) => (a.ordem ?? 0) - (b.ordem ?? 0))
  .filter((t: any) => {
    return Boolean(
      String(t.tipo || "").trim() ||
        String(t.fornecedor || "").trim() ||
        String(t.descricao || "").trim() ||
        String(t.data_inicio || "").trim() ||
        String(t.data_fim || "").trim() ||
        String(t.categoria || "").trim() ||
        String(t.observacao || "").trim()
    );
  });

const investimentos = (roteiro.roteiro_investimento || [])
  .slice()
  .sort((a: any, b: any) => (a.ordem ?? 0) - (b.ordem ?? 0))
  .filter((i: any) => {
    return Boolean(
      Number(i.valor_por_pessoa || 0) > 0 || Number(i.qtd_apto || 0) > 0 || Number(i.valor_por_apto || 0) > 0
    );
  });

const pagamentos = (roteiro.roteiro_pagamento || [])
  .slice()
  .sort((a: any, b: any) => (a.ordem ?? 0) - (b.ordem ?? 0))
  .filter((p: any) => {
    return Boolean(
      String(p.servico || "").trim() ||
        String(p.forma_pagamento || "").trim() ||
        Number(p.valor_total_com_taxas || 0) > 0 ||
        Number(p.taxas || 0) > 0
    );
  });

const incluiItems = splitLines(roteiro?.inclui_texto);
const naoIncluiItems = splitLines(roteiro?.nao_inclui_texto);

const infoImportanteItems = splitLines(roteiro?.informacoes_importantes || "");

const dateCandidates: Date[] = [];
for (const d of dias) {
  const dt = toDateOrNull(d.data);
  if (dt) dateCandidates.push(dt);
}
for (const h of hoteis) {
  const di = toDateOrNull(h.data_inicio);
  const df = toDateOrNull(h.data_fim);
  if (di) dateCandidates.push(di);
  if (df) dateCandidates.push(df);
}
for (const p of passeios) {
  const di = toDateOrNull(p.data_inicio);
  const df = toDateOrNull(p.data_fim);
  if (di) dateCandidates.push(di);
  if (df) dateCandidates.push(df);
}
for (const t of transportes) {
  const di = toDateOrNull(t.data_inicio);
  const df = toDateOrNull(t.data_fim);
  if (di) dateCandidates.push(di);
  if (df) dateCandidates.push(df);
}

let startDate: Date | null = null;
let endDate: Date | null = null;
if (dateCandidates.length) {
  startDate = dateCandidates.reduce((min, d) => (d.getTime() < min.getTime() ? d : min), dateCandidates[0]);
  endDate = dateCandidates.reduce((max, d) => (d.getTime() > max.getTime() ? d : max), dateCandidates[0]);
}

const activePage = "orcamentos";
const pageTitle = `Visualizar: ${roteiro?.nome || "Orçamento"}`;
---

<DashboardLayout title={pageTitle} {activePage}>
  <HeaderPage
    title={roteiro?.nome || "Orçamento Personalizado"}
    subtitle="Visualização em HTML (sem PDF)."
    color="purple"
    stackActionsOnMobile={true}
  >
    <div class="mobile-stack-buttons">
      <a class="btn btn-primary" href={`/orcamentos/personalizados/${roteiroId}`}>Editar</a>
      <a class="btn btn-light" href="/orcamentos/personalizados">Voltar</a>
    </div>
  </HeaderPage>

  <div class="px-6 pb-10">
    <div class="max-w-5xl mx-auto space-y-4">
      <div class="bg-white border border-slate-200 rounded-xl p-5">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <div class="text-xs font-semibold text-slate-600">Origem</div>
            <div class="text-base text-slate-900 mt-1">{roteiro?.inicio_cidade || "—"}</div>
          </div>
          <div>
            <div class="text-xs font-semibold text-slate-600">Destino</div>
            <div class="text-base text-slate-900 mt-1">{roteiro?.fim_cidade || "—"}</div>
          </div>
          <div>
            <div class="text-xs font-semibold text-slate-600">Período</div>
            <div class="text-base text-slate-900 mt-1">
              {startDate && endDate ? `${startDate.toLocaleDateString("pt-BR")} a ${endDate.toLocaleDateString("pt-BR")}` : (roteiro?.duracao ? `${roteiro.duracao} dias` : "—")}
            </div>
          </div>
        </div>
      </div>

      {dias.length > 0 ? (
        <>
          <!-- Itinerário Detalhado -->
          <div class="bg-white border border-slate-200 rounded-xl p-4">
            <div class="text-lg md:text-xl font-extrabold text-blue-title">Itinerário Detalhado</div>
          </div>
          <div class="bg-white border border-slate-200 rounded-xl p-5">
            <div class="space-y-4">
              {dias.map((d: any, idx: number) => {
                const place = String(d.percurso || "").trim() || String(d.cidade || "").trim();
                const header = [formatDate(d.data), `Dia ${idx + 1}${place ? `: ${place}` : ""}`].filter(Boolean).join(" — ");
                const items = splitParagraphs(d.descricao);
                return (
                  <div class="border border-slate-200 rounded-lg p-4" key={d.id || idx}>
                    <div class="text-sm font-semibold text-slate-900">{header || `Dia ${idx + 1}`}</div>
                    {items.length > 0 ? (
                      <ul class="mt-2 list-disc pl-5 text-sm text-slate-700 space-y-1">
                        {items.map((it, i) => (
                          <li key={i}>{it}</li>
                        ))}
                      </ul>
                    ) : null}
                  </div>
                );
              })}
            </div>
          </div>
        </>
      ) : null}

      {hoteis.length > 0 ? (
        <>
          <!-- Hotéis Sugeridos -->
          <div class="bg-white border border-slate-200 rounded-xl p-4">
            <div class="text-lg md:text-xl font-extrabold text-blue-title">Hotéis Sugeridos</div>
          </div>
          <div class="bg-white border border-slate-200 rounded-xl p-5">
            <div class="space-y-3">
              {hoteis.map((h: any, idx: number) => {
                const title = [h.cidade, h.hotel].filter(Boolean).join(" | ") || `Hotel ${idx + 1}`;
                const range = [formatDate(h.data_inicio), formatDate(h.data_fim)].filter(Boolean).join(" a ");
                return (
                  <div class="border border-slate-200 rounded-lg p-4" key={h.id || idx}>
                    <div class="text-sm font-semibold text-slate-900">{title}</div>
                    <div class="mt-1 text-sm text-slate-700">
                      {[range, h.noites ? `${h.noites} noite${Number(h.noites) === 1 ? "" : "s"}` : ""].filter(Boolean).join(" • ")}
                    </div>
                    <div class="mt-1 text-xs text-slate-600">
                      {[
                        h.categoria ? `Categoria: ${h.categoria}` : "",
                        h.regime ? `Regime: ${h.regime}` : "",
                        h.apto ? `Apto: ${h.apto}` : "",
                      ].filter(Boolean).join(" • ")}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </>
      ) : null}

      {passeios.length > 0 ? (
        <>
          <!-- Passeios Principais -->
          <div class="bg-white border border-slate-200 rounded-xl p-4">
            <div class="text-lg md:text-xl font-extrabold text-blue-title">Passeios Principais</div>
          </div>
          <div class="bg-white border border-slate-200 rounded-xl p-5">
            <div class="space-y-3">
              {passeios.map((p: any, idx: number) => {
            const title = [p.cidade, p.passeio].filter(Boolean).join(" | ") || `Passeio ${idx + 1}`;
            const di = formatDate(p.data_inicio);
            const df = formatDate(p.data_fim);
            const when = di && df ? (di === df ? di : `${di} a ${df}`) : (di || df);
            return (
              <div class="border border-slate-200 rounded-lg p-4" key={p.id || idx}>
                <div class="text-sm font-semibold text-slate-900">{title}</div>
                <div class="mt-1 text-sm text-slate-700">
                  {[when, p.tipo, p.ingressos].filter(Boolean).join(" • ") || "—"}
                </div>
              </div>
            );
              })}
            </div>
          </div>
        </>
      ) : null}

      {transportes.length > 0 ? (
        <>
          <!-- Transporte Incluído -->
          <div class="bg-white border border-slate-200 rounded-xl p-4">
            <div class="text-lg md:text-xl font-extrabold text-blue-title">Transporte Incluído</div>
          </div>
          <div class="bg-white border border-slate-200 rounded-xl p-5">
            <div class="space-y-3">
              {transportes.map((t: any, idx: number) => {
            const di = formatDate(t.data_inicio);
            const df = formatDate(t.data_fim);
            const when = di && df ? (di === df ? di : `${di} a ${df}`) : (di || df);
            const title = [t.tipo, t.fornecedor].filter(Boolean).join(" | ") || `Transporte ${idx + 1}`;
            return (
              <div class="border border-slate-200 rounded-lg p-4" key={t.id || idx}>
                <div class="text-sm font-semibold text-slate-900">{title}</div>
                <div class="mt-1 text-sm text-slate-700">{[when, t.descricao, t.categoria].filter(Boolean).join(" • ") || "—"}</div>
                {t.observacao ? <div class="mt-1 text-xs text-slate-600">Obs.: {t.observacao}</div> : null}
              </div>
            );
              })}
            </div>
          </div>
        </>
      ) : null}

      {investimentos.length > 0 ? (
        <>
          <!-- Investimento -->
          <div class="bg-white border border-slate-200 rounded-xl p-4">
            <div class="text-lg md:text-xl font-extrabold text-blue-title">Investimento</div>
          </div>
          <div class="bg-white border border-slate-200 rounded-xl p-5">
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="text-left text-slate-600">
                    <th class="py-2 pr-3">Tipo</th>
                    <th class="py-2 pr-3 whitespace-nowrap">Valor por Pessoa</th>
                    <th class="py-2 pr-3 whitespace-nowrap">Qte Pax</th>
                    <th class="py-2 pr-3 whitespace-nowrap">Valor por Apto</th>
                  </tr>
                </thead>
                <tbody>
                  {investimentos.map((i: any, idx: number) => (
                    <tr class="border-t border-slate-200" key={i.id || idx}>
                      <td class="py-2 pr-3 text-slate-900">{i.tipo || "—"}</td>
                      <td class="py-2 pr-3 text-slate-700 whitespace-nowrap">{formatCurrency(i.valor_por_pessoa)}</td>
                      <td class="py-2 pr-3 text-slate-700 whitespace-nowrap">{Number(i.qtd_apto || 0) || "—"}</td>
                      <td class="py-2 pr-3 text-slate-700 whitespace-nowrap">{formatCurrency(i.valor_por_apto)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </>
      ) : null}

      {pagamentos.length > 0 ? (
        <>
          <!-- Formas de Pagamento -->
          <div class="bg-white border border-slate-200 rounded-xl p-4">
            <div class="text-lg md:text-xl font-extrabold text-blue-title">Formas de Pagamento</div>
          </div>
          <div class="bg-white border border-slate-200 rounded-xl p-5">
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="text-left text-slate-600">
                    <th class="py-2 pr-3">Serviço</th>
                    <th class="py-2 pr-3 whitespace-nowrap">Valor Total c/ Taxas</th>
                    <th class="py-2 pr-3 whitespace-nowrap">Taxas</th>
                    <th class="py-2 pr-3 whitespace-nowrap">Forma</th>
                  </tr>
                </thead>
                <tbody>
                  {pagamentos.map((p: any, idx: number) => (
                    <tr class="border-t border-slate-200" key={p.id || idx}>
                      <td class="py-2 pr-3 text-slate-900">{p.servico || "—"}</td>
                      <td class="py-2 pr-3 text-slate-700 whitespace-nowrap">{formatCurrency(p.valor_total_com_taxas)}</td>
                      <td class="py-2 pr-3 text-slate-700 whitespace-nowrap">{formatCurrency(p.taxas)}</td>
                      <td class="py-2 pr-3 text-slate-700">
                        {(() => {
                          const lines = splitLines(p.forma_pagamento || "");
                          if (!lines.length) return "—";
                          if (lines.length === 1) return lines[0];
                          return (
                            <ul class="list-disc pl-5 text-sm text-slate-700 space-y-1">
                              {lines.map((it: string, i: number) => (
                                <li key={i}>{it}</li>
                              ))}
                            </ul>
                          );
                        })()}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </>
      ) : null}

      {incluiItems.length > 0 || naoIncluiItems.length > 0 ? (
        <>
          <!-- Incluído / Não Incluído -->
          <div class="bg-white border border-slate-200 rounded-xl p-4">
            <div class="text-lg md:text-xl font-extrabold text-blue-title">Incluído / Não Incluído</div>
          </div>
          <div class="bg-white border border-slate-200 rounded-xl p-5">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {incluiItems.length > 0 ? (
                <div class="border border-slate-200 rounded-lg p-4">
                  <div class="text-sm font-semibold text-slate-900">Incluído</div>
                  <ul class="mt-2 list-disc pl-5 text-sm text-slate-700 space-y-1">
                    {incluiItems.map((it, i) => (
                      <li key={i}>{it}</li>
                    ))}
                  </ul>
                </div>
              ) : null}
              {naoIncluiItems.length > 0 ? (
                <div class="border border-slate-200 rounded-lg p-4">
                  <div class="text-sm font-semibold text-slate-900">Não Incluído</div>
                  <ul class="mt-2 list-disc pl-5 text-sm text-slate-700 space-y-1">
                    {naoIncluiItems.map((it, i) => (
                      <li key={i}>{it}</li>
                    ))}
                  </ul>
                </div>
              ) : null}
            </div>
          </div>
        </>
      ) : null}

      {infoImportanteItems.length > 0 ? (
        <>
          <!-- Informações Importantes -->
          <div class="bg-white border border-slate-200 rounded-xl p-4">
            <div class="text-lg md:text-xl font-extrabold text-blue-title">Informações Importantes</div>
          </div>
          <div class="bg-white border border-slate-200 rounded-xl p-5">
            <ul class="list-disc pl-5 text-sm text-slate-700 space-y-1">
              {infoImportanteItems.map((it, i) => (
                <li key={i}>{it}</li>
              ))}
            </ul>
          </div>
        </>
      ) : null}
    </div>
  </div>
</DashboardLayout>
