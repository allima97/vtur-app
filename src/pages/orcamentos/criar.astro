---
import "../../styles/global.css";
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import QuoteManualIsland from "../../components/islands/QuoteManualIsland";
import { createAstroServerClient } from "../../lib/supabaseAstro";

const supabaseAuth = createAstroServerClient(Astro);

const {
  data: { user },
} = await supabaseAuth.auth.getUser();

if (!user) {
  return Astro.redirect("/auth/login");
}

const activePage = "orcamentos";
---

<DashboardLayout title="Orcamentos" {activePage}>
  <QuoteManualIsland client:visible />
</DashboardLayout>
