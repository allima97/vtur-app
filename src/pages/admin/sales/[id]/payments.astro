---
import "../../../../styles/global.css";
import { supabaseServer as supabase } from "../../../../lib/supabaseServer";
import { toISODateLocal } from "../../../../lib/dateTime";
import Button from "../../../../components/ui/Button.astro";

const saleId = Astro.params.id;
const pathname = new URL(Astro.request.url).pathname;
const supabaseAny = supabase as any;

type SaleRecord = {
  id: string;
  client_id: string | null;
  seller_id: string | null;
  total: number | string;
  paid_total: number | string;
  balance_due: number | string;
  currency: string;
  financial_status: string;
};

type ClientRecord = {
  nome: string | null;
};

type SellerRecord = {
  nome_completo: string | null;
};

type PaymentRecord = {
  id: string;
  method: string;
  amount: number | string;
  status: string;
  created_at: string;
};

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const intent = String(formData.get("intent") ?? "");

  if (intent === "simple") {
    const amount = Number(formData.get("amount"));
    const method = String(formData.get("method") ?? "");
    const { error } = await supabaseAny.rpc("registrar_pagamento_simples", {
      p_sale_id: saleId,
      p_method: method,
      p_amount: amount,
    });
    if (error) throw error;
    return Astro.redirect(pathname);
  }

  if (intent === "installments") {
    const total = Number(formData.get("total"));
    const installments = Number(formData.get("installments"));
    const { error } = await supabaseAny.rpc("registrar_pagamento_parcelado", {
      p_sale_id: saleId,
      p_method: "CREDIT_CARD",
      p_total_amount: total,
      p_installments: installments,
      p_first_due_date: toISODateLocal(new Date()),
    });
    if (error) throw error;
    return Astro.redirect(pathname);
  }
}

/* 1️⃣ VENDA (SEM JOIN) */
const { data: saleData, error: saleError } = await supabaseAny
  .from("sale")
  .select(`
    id,
    client_id,
    seller_id,
    total,
    paid_total,
    balance_due,
    currency,
    financial_status
  `)
  .eq("id", saleId)
  .single();

const sale = saleData as SaleRecord | null;

if (!sale) {
  console.error(saleError);
  throw new Error("Venda não encontrada");
}

/* 2️⃣ CLIENTE */
const { data: clientData } = await supabaseAny
  .from("clientes")
  .select("nome")
  .eq("id", sale.client_id)
  .single();

const client = clientData as ClientRecord | null;

/* 3️⃣ VENDEDOR */
const { data: sellerData } = await supabaseAny
  .from("users")
  .select("nome_completo")
  .eq("id", sale.seller_id)
  .single();

const seller = sellerData as SellerRecord | null;

/* 4️⃣ PAGAMENTOS */
const { data: paymentsData } = await supabaseAny
  .from("payment")
  .select(`
    id,
    method,
    amount,
    status,
    created_at
  `)
  .eq("sale_id", saleId)
  .order("created_at", { ascending: false });

const payments = (paymentsData ?? []) as PaymentRecord[];
const clientName = client?.nome ?? "-";
const sellerName = seller?.nome_completo ?? "-";
---

<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <style>
      body {
        font-family: Inter, "Segoe UI", Roboto, sans-serif;
        margin: 0;
        padding: 24px;
      }

      .page {
        max-width: 920px;
        margin: 0 auto;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        box-shadow: 0 16px 36px rgba(15, 23, 42, 0.12);
        padding: 24px;
      }

      h1, h2 {
        color: #0f172a;
      }

      p, li, label {
        color: #334155;
      }

      form {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 8px;
      }

      input, select {
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        padding: 8px 10px;
        min-height: 36px;
      }
    </style>
  </head>
  <body class="sakai-theme">
    <div class="page">
    <h1>Pagamentos da Venda</h1>

    <p>
      Cliente: <strong>{clientName}</strong><br />
      Vendedor: <strong>{sellerName}</strong>
    </p>

    <hr />

    <p>
      <strong>Total:</strong> {sale.currency} {sale.total}<br />
      <strong>Pago:</strong> {sale.currency} {sale.paid_total}<br />
      <strong>Saldo:</strong> {sale.currency} {sale.balance_due}<br />
      <strong>Status:</strong> {sale.financial_status}
    </p>

    <hr />

    <h2>Registrar pagamento (PIX / Transferência)</h2>
    <form method="post" action={pathname}>
      <input type="hidden" name="intent" value="simple" />
      <input type="number" step="0.01" name="amount" placeholder="Valor" required />
      <select name="method">
        <option value="PIX">PIX</option>
        <option value="BANK_TRANSFER">Transferência</option>
        <option value="CASH">Dinheiro</option>
      </select>
      <Button type="submit">Registrar pagamento</Button>
    </form>

    <hr />

    <h2>Pagamento com cartão (parcelado)</h2>
    <form method="post" action={pathname}>
      <input type="hidden" name="intent" value="installments" />
      <input type="number" step="0.01" name="total" placeholder="Valor total" required />
      <input type="number" name="installments" placeholder="Parcelas" min="1" max="12" required />
      <Button type="submit">Criar parcelamento</Button>
    </form>

    <hr />

    <h2>Pagamentos registrados</h2>
    <ul>
      {payments?.map((p) => (
        <li>
          {p.method} — {sale.currency} {p.amount} — {p.status}
        </li>
      ))}
    </ul>

    <p>
      <a href={`/admin/sales/${saleId}`}>⬅ Voltar para a venda</a>
    </p>
    </div>
  </body>
</html>
