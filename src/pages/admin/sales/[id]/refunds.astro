---
import "../../../../styles/global.css";
import { supabaseServer as supabase } from "../../../../lib/supabaseServer";
import Button from "../../../../components/ui/Button.astro";

const saleId = Astro.params.id;
const pathname = new URL(Astro.request.url).pathname;
const supabaseAny = supabase as any;

type SaleRecord = {
  id: string;
  total: number | string;
  paid_total: number | string;
  balance_due: number | string;
  currency: string;
  status: string;
  financial_status: string;
};

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const intent = String(formData.get("intent") ?? "");

  if (intent === "refund") {
    const amount = Number(formData.get("amount"));
    const reason = String(formData.get("reason") ?? "");
    const { error } = await supabaseAny.rpc("registrar_estorno", {
      p_sale_id: saleId,
      p_amount: amount,
      p_reason: reason,
    });
    if (error) throw error;
    return Astro.redirect(pathname);
  }

  if (intent === "cancel") {
    const reason = String(formData.get("reason") ?? "");
    const penalty = Number(formData.get("penalty") ?? 0);
    const { error } = await supabaseAny.rpc("cancelar_venda", {
      p_sale_id: saleId,
      p_reason: reason,
      p_penalty: penalty,
    });
    if (error) throw error;
    return Astro.redirect(pathname);
  }
}

/* 1️⃣ VENDA */
const { data: saleData, error } = await supabaseAny
  .from("sale")
  .select(`
    id,
    total,
    paid_total,
    balance_due,
    currency,
    status,
    financial_status
  `)
  .eq("id", saleId)
  .single();

const sale = saleData as SaleRecord | null;

if (!sale) {
  console.error(error);
  throw new Error("Venda não encontrada");
}
---

<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <style>
      body {
        font-family: Inter, "Segoe UI", Roboto, sans-serif;
        margin: 0;
        padding: 24px;
      }

      .page {
        max-width: 920px;
        margin: 0 auto;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        box-shadow: 0 16px 36px rgba(15, 23, 42, 0.12);
        padding: 24px;
      }

      h1, h2 {
        color: #0f172a;
      }

      p, li, label {
        color: #334155;
      }

      form {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 8px;
      }

      input {
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        padding: 8px 10px;
        min-height: 36px;
      }
    </style>
  </head>
  <body class="sakai-theme">
    <div class="page">
    <h1>Estorno / Cancelamento</h1>

    <p>
      <strong>Status venda:</strong> {sale.status}<br />
      <strong>Status financeiro:</strong> {sale.financial_status}
    </p>

    <p>
      <strong>Total:</strong> {sale.currency} {sale.total}<br />
      <strong>Pago:</strong> {sale.currency} {sale.paid_total}<br />
      <strong>Saldo:</strong> {sale.currency} {sale.balance_due}
    </p>

    <hr />

    <h2>Estorno</h2>
    <form method="post" action={pathname}>
      <input type="hidden" name="intent" value="refund" />
      <input
        type="number"
        step="0.01"
        name="amount"
        placeholder="Valor do estorno"
        required
      />
      <input
        type="text"
        name="reason"
        placeholder="Motivo do estorno"
      />
      <Button type="submit">Registrar estorno</Button>
    </form>

    <hr />

    <h2>Cancelar venda</h2>
    <form method="post" action={pathname}>
      <input type="hidden" name="intent" value="cancel" />
      <input
        type="text"
        name="reason"
        placeholder="Motivo do cancelamento"
        required
      />
      <input
        type="number"
        step="0.01"
        name="penalty"
        placeholder="Multa (se houver)"
      />
      <Button type="submit">
        Cancelar venda
      </Button>
    </form>

    <hr />

    <p>
      <a href={`/admin/sales/${saleId}`}>⬅ Voltar para a venda</a>
    </p>
    </div>
  </body>
</html>
