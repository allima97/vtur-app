---
import "../../styles/global.css";
import "../../styles/auth-extra.css";
import "../../styles/sakai-alignment.css";
import BrandHead from "../../components/BrandHead.astro";
import AuthRecoverIsland from "../../components/islands/AuthRecoverIsland";
import { SYSTEM_NAME } from "../../lib/systemName";

const pageTitle = `Recuperar senha - ${SYSTEM_NAME}`;
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <BrandHead title={pageTitle} canonicalPath={Astro.url.pathname} noindex={true} />
    <title>{pageTitle}</title>
  </head>
  <body class="auth-body">
    <AuthRecoverIsland client:visible />
  </body>
</html>
