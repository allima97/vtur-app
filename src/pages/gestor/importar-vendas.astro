---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import HeaderPage from "../../components/ui/HeaderPage.astro";
import ImportarVendasIsland from "../../components/islands/ImportarVendasIsland.tsx";

const activePage = "importar-vendas";
---

<DashboardLayout title="Importar Vendas" {activePage} module="Vendas">
