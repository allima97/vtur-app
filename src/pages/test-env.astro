---
import "../styles/global.css";
import { readEnv } from "../lib/supabaseServer";

const supabaseUrl = readEnv("PUBLIC_SUPABASE_URL") || "";
const supabaseAnonKey = readEnv("PUBLIC_SUPABASE_ANON_KEY") || "";

const mask = (value: string) =>
  value ? `${value.slice(0, 6)}…${value.slice(-4)}` : "—";
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Test Env</title>
    <style>
      body {
        font-family: Inter, "Segoe UI", Roboto, sans-serif;
        color: #0f172a;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
      }
      .card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 20px 24px;
        max-width: 520px;
        width: 100%;
        box-shadow: 0 16px 36px rgba(15, 23, 42, 0.14);
      }
      h1 {
        margin: 0 0 12px;
        font-size: 1.5rem;
        color: #1d4ed8;
      }
      p {
        margin: 0 0 12px;
        color: #475569;
      }
      ul {
        list-style: none;
        padding: 0;
        margin: 0 0 12px;
        display: grid;
        gap: 8px;
      }
      li {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 10px 12px;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .ok {
        color: #22c55e;
      }
      .missing {
        color: #f97316;
      }
      code {
        background: #eff6ff;
        padding: 2px 6px;
        border-radius: 6px;
        border: 1px solid #bfdbfe;
      }
    </style>
  </head>
  <body class="sakai-theme">
    <div class="card">
      <h1>Diagnóstico de Variáveis</h1>
      <p>
        Confirme se as variáveis públicas do Supabase estão chegando no build e
        no runtime.
      </p>
      <ul>
        <li>
          <span>PUBLIC_SUPABASE_URL</span>
          <span class={supabaseUrl ? "ok" : "missing"}>
            {supabaseUrl ? mask(supabaseUrl) : "MISSING"}
          </span>
        </li>
        <li>
          <span>PUBLIC_SUPABASE_ANON_KEY</span>
          <span class={supabaseAnonKey ? "ok" : "missing"}>
            {supabaseAnonKey ? mask(supabaseAnonKey) : "MISSING"}
          </span>
        </li>
      </ul>
      <p>
        Se estiver marcado como <strong>MISSING</strong>, adicione as variáveis
        no Worker (<code>Workers → Settings → Variables</code>) ou em
        <code>.env</code> local e publique novamente.
      </p>
    </div>
  </body>
</html>
