---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import HeaderPage from "../../components/ui/HeaderPage.astro";
import ClientesConsultaIsland from "../../components/islands/ClientesConsultaIsland.tsx";

const activePage = "clientes";
---

<DashboardLayout title="Carteira de Clientes" {activePage}>
  <style is:global>
    @media (max-width: 640px) {
      .clientes-page .table-container {
        max-height: none !important;
        overflow: visible !important;
        overflow-y: visible !important;
      }
    }
  </style>

  <div class="page-content-wrap">
    <HeaderPage
      title="Carteira de Clientes"
      subtitle="Gerencie seus clientes com visão de CRM."
      color="blue"
    />

    <ClientesConsultaIsland client:load />
  </div>
</DashboardLayout>
