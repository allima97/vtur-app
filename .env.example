PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Valores usados apenas no servidor (middleware e páginas SSR)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cache persistente local (Dexie + IndexedDB). 1 = ativo / 0 = desativado
PUBLIC_PERSISTENT_CACHE_ENABLED=1

# Sync opcional com Dexie Cloud para o cache persistente.
# Deixe em 0 para manter apenas local no navegador.
PUBLIC_DEXIE_CLOUD_SYNC_ENABLED=0
PUBLIC_DEXIE_CLOUD_DB_URL=
# Escopos permitidos para sync cloud (csv). Use * para tudo.
PUBLIC_DEXIE_CLOUD_SYNC_SCOPES=*
